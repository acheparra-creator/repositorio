# Sci-Hub-Search Environment Variables Configuration Example
# Copy this file to .env and fill in your actual configuration

# ============================================
# Optional: Sci-Hub Configuration
# ============================================

# Sci-Hub base URL (optional - auto-detected if not specified)
# Examples: https://sci-hub.se, https://sci-hub.st, https://sci-hub.ru
# Leave empty to let the library automatically find available mirrors
SCIHUB_BASE_URL=

# Download timeout in seconds (default: 30)
DOWNLOAD_TIMEOUT=30

# ============================================
# Notes
# ============================================

# Most features work without any configuration.
# The Sci-Hub library will automatically try different mirrors.
# If you experience issues, you can specify a particular mirror.
